{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://acip.local/cf-gb/task-manifest.schema.json",
  "title": "CF/GB Phase -1 Task Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest_version", "business_id", "root_path", "artifact_root", "path_resolution", "state_model", "tasks"],
  "properties": {
    "manifest_version": {"type": "string", "const": "1.0"},
    "business_id": {"type": "string", "const": "cf_gb_relative_system"},
    "root_path": {"type": "string", "const": "businesses/cf_gb_relative_system"},
    "artifact_root": {"type": "string", "const": "businesses/cf_gb_relative_system/artifacts"},
    "path_resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo_prefixes", "default_base"],
      "properties": {
        "repo_prefixes": {"type": "array", "items": {"type": "string"}},
        "default_base": {"type": "string", "const": "root_path"}
      }
    },
    "state_model": {
      "type": "array",
      "items": {"enum": ["ready", "blocked", "running", "succeeded", "failed", "quarantined"]},
      "uniqueItems": true
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/task"}
    }
  },
  "$defs": {
    "stringList": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {"enum": ["command", "interactive_agent", "http", "scheduled_job"]},
        "workflow": {"type": "string"},
        "command": {"type": "string"},
        "endpoint": {"type": "string"}
      },
      "allOf": [
        {"if": {"properties": {"kind": {"const": "interactive_agent"}}}, "then": {"required": ["workflow"]}},
        {"if": {"properties": {"kind": {"const": "command"}}}, "then": {"required": ["command"]}},
        {"if": {"properties": {"kind": {"const": "http"}}}, "then": {"required": ["endpoint"]}}
      ]
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "wp", "title", "state", "depends", "executor", "supervisor", "trigger", "execution", "inputs", "targets", "outputs", "acceptance", "reliability", "next"],
      "properties": {
        "id": {"type": "string", "pattern": "^E-[0-9]{3}[A-Z]$"},
        "wp": {"type": "string", "pattern": "^WP-E(?:[1-9]|10)$"},
        "title": {"type": "string", "minLength": 3},
        "state": {"enum": ["ready", "blocked", "running", "succeeded", "failed", "quarantined"]},
        "depends": {"$ref": "#/$defs/stringList"},
        "executor": {"type": "string"},
        "supervisor": {"type": "string"},
        "trigger": {"type": "string"},
        "execution": {"$ref": "#/$defs/execution"},
        "inputs": {"$ref": "#/$defs/stringList"},
        "targets": {"$ref": "#/$defs/stringList"},
        "outputs": {"$ref": "#/$defs/stringList"},
        "acceptance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["commands", "criteria"],
          "properties": {
            "commands": {"$ref": "#/$defs/stringList"},
            "criteria": {"$ref": "#/$defs/stringList"}
          }
        },
        "reliability": {
          "type": "object",
          "additionalProperties": false,
          "required": ["timeout_seconds", "max_attempts", "failure_state"],
          "properties": {
            "timeout_seconds": {"type": "integer", "minimum": 1},
            "max_attempts": {"type": "integer", "minimum": 1},
            "failure_state": {"enum": ["failed", "quarantined"]}
          }
        },
        "next": {"$ref": "#/$defs/stringList"}
        ,"input_schema": {"type": "string"}
        ,"output_schema": {"type": "string"}
        ,"statistical_method": {"type": "string"}
      }
    }
  }
}
