{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://acip.local/cf-gb-relative-system/schemas/study/v1",
  "title": "Study registration",
  "description": "Machine-readable preregistration required before data collection starts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "study_id",
    "question",
    "population",
    "frame",
    "unit",
    "estimand",
    "primary_metric",
    "precision",
    "stopping",
    "sample_size_method",
    "missingness",
    "analysis_code_version"
  ],
  "properties": {
    "schema_version": {
      "const": "study:v1"
    },
    "study_id": {
      "type": "string",
      "pattern": "^study_[a-z0-9][a-z0-9_-]{5,63}$"
    },
    "question": {
      "type": "string",
      "minLength": 10
    },
    "population": {
      "type": "string",
      "minLength": 3
    },
    "frame": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "coverage_limitations"
      ],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 3
        },
        "coverage_limitations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          }
        }
      }
    },
    "unit": {
      "type": "string",
      "minLength": 2
    },
    "strata": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "minimum_n"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "minimum_n": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "estimand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "target"
      ],
      "properties": {
        "kind": {
          "enum": [
            "proportion",
            "mean",
            "difference",
            "rate",
            "non_inferiority"
          ]
        },
        "target": {
          "type": "string",
          "minLength": 3
        }
      }
    },
    "primary_metric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "formula",
        "window",
        "timezone"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 3
        },
        "formula": {
          "type": "string",
          "minLength": 3
        },
        "window": {
          "type": "string",
          "minLength": 2
        },
        "timezone": {
          "type": "string",
          "minLength": 2
        }
      }
    },
    "precision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "value"
      ],
      "properties": {
        "kind": {
          "enum": [
            "ci_half_width",
            "mde",
            "non_inferiority_margin"
          ]
        },
        "value": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "stopping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule",
        "decision_boundary"
      ],
      "properties": {
        "rule": {
          "type": "string",
          "minLength": 3
        },
        "decision_boundary": {
          "type": "string",
          "minLength": 3
        }
      }
    },
    "sample_size_method": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "library",
        "version",
        "inputs"
      ],
      "properties": {
        "library": {
          "type": "string",
          "minLength": 2
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "inputs": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": true
        }
      }
    },
    "missingness": {
      "type": "string",
      "minLength": 3
    },
    "analysis_code_version": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]{4,128}$"
    }
  }
}
