{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://acip.local/cf-gb-relative-system/schemas/research-artifact/v1",
  "title": "Research artifact",
  "description": "Versioned research output with preregistered study and statistically valid result summary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_id",
    "task_id",
    "producer",
    "generated_at",
    "payload_schema",
    "payload_path",
    "content_hash",
    "provenance",
    "payload"
  ],
  "properties": {
    "schema_version": {
      "const": "artifact-envelope:v1"
    },
    "artifact_id": {
      "type": "string",
      "pattern": "^[A-Z]-[0-9]{3}[A-Z]/[a-z0-9][a-z0-9._-]{2,127}$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^E-[0-9]{3}[A-Z]$"
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "worker_id",
        "execution_kind",
        "version"
      ],
      "properties": {
        "role": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{1,63}$"
        },
        "worker_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._/-]{2,127}$"
        },
        "execution_kind": {
          "enum": [
            "interactive_agent",
            "command",
            "manual_import"
          ]
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "payload_schema": {
      "const": "research-artifact:v1"
    },
    "payload_path": {
      "type": "string",
      "pattern": "^businesses/cf_gb_relative_system/artifacts/E-[0-9]{3}[A-Z]/[A-Za-z0-9._/-]+$"
    },
    "content_hash": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "hex"
      ],
      "properties": {
        "algorithm": {
          "const": "sha256"
        },
        "hex": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "business_id",
        "manifest_version",
        "input_artifacts",
        "canonical_sources",
        "code_version"
      ],
      "properties": {
        "business_id": {
          "const": "cf_gb_relative_system"
        },
        "manifest_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "input_artifacts": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^businesses/cf_gb_relative_system/[A-Za-z0-9._/-]+$"
          },
          "uniqueItems": true
        },
        "canonical_sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_./-]{3,255}$"
          },
          "uniqueItems": true
        },
        "code_version": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "git_commit",
            "dirty"
          ],
          "properties": {
            "git_commit": {
              "type": "string",
              "pattern": "^[a-f0-9]{7,40}$"
            },
            "dirty": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "study",
        "result"
      ],
      "properties": {
        "study": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schema_version",
            "study_id",
            "question",
            "population",
            "frame",
            "unit",
            "estimand",
            "primary_metric",
            "precision",
            "stopping",
            "sample_size_method",
            "missingness",
            "analysis_code_version"
          ],
          "properties": {
            "schema_version": {
              "const": "study:v1"
            },
            "study_id": {
              "type": "string",
              "pattern": "^study_[a-z0-9][a-z0-9_-]{5,63}$"
            },
            "question": {
              "type": "string",
              "minLength": 10
            },
            "population": {
              "type": "string",
              "minLength": 3
            },
            "frame": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "description",
                "coverage_limitations"
              ],
              "properties": {
                "description": {
                  "type": "string",
                  "minLength": 3
                },
                "coverage_limitations": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 3
                  }
                }
              }
            },
            "unit": {
              "type": "string",
              "minLength": 2
            },
            "estimand": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "kind",
                "target"
              ],
              "properties": {
                "kind": {
                  "enum": [
                    "proportion",
                    "mean",
                    "difference",
                    "rate",
                    "non_inferiority"
                  ]
                },
                "target": {
                  "type": "string",
                  "minLength": 3
                }
              }
            },
            "primary_metric": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "name",
                "formula",
                "window",
                "timezone"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 3
                },
                "formula": {
                  "type": "string",
                  "minLength": 3
                },
                "window": {
                  "type": "string",
                  "minLength": 2
                },
                "timezone": {
                  "type": "string",
                  "minLength": 2
                }
              }
            },
            "precision": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "kind",
                "value"
              ],
              "properties": {
                "kind": {
                  "enum": [
                    "ci_half_width",
                    "mde",
                    "non_inferiority_margin"
                  ]
                },
                "value": {
                  "type": "number",
                  "exclusiveMinimum": 0
                }
              }
            },
            "stopping": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "rule",
                "decision_boundary"
              ],
              "properties": {
                "rule": {
                  "type": "string",
                  "minLength": 3
                },
                "decision_boundary": {
                  "type": "string",
                  "minLength": 3
                }
              }
            },
            "sample_size_method": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "library",
                "version",
                "inputs"
              ],
              "properties": {
                "library": {
                  "type": "string",
                  "minLength": 2
                },
                "version": {
                  "type": "string",
                  "minLength": 1
                },
                "inputs": {
                  "type": "object",
                  "minProperties": 1,
                  "additionalProperties": true
                }
              }
            },
            "missingness": {
              "type": "string",
              "minLength": 3
            },
            "analysis_code_version": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._:-]{4,128}$"
            }
          }
        },
        "result": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "estimate",
            "standard_error",
            "confidence_interval",
            "sample_size",
            "missing_count",
            "excluded_count",
            "protocol_deviations",
            "decision_status",
            "code_version",
            "data_version"
          ],
          "properties": {
            "estimate": {
              "type": "number"
            },
            "standard_error": {
              "type": "number",
              "minimum": 0
            },
            "confidence_interval": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "level",
                "lower",
                "upper"
              ],
              "properties": {
                "level": {
                  "type": "number",
                  "exclusiveMinimum": 0,
                  "maximum": 1
                },
                "lower": {
                  "type": "number"
                },
                "upper": {
                  "type": "number"
                }
              }
            },
            "sample_size": {
              "type": "integer",
              "minimum": 1
            },
            "missing_count": {
              "type": "integer",
              "minimum": 0
            },
            "excluded_count": {
              "type": "integer",
              "minimum": 0
            },
            "protocol_deviations": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 3
              }
            },
            "decision_status": {
              "enum": [
                "valid",
                "invalid",
                "inconclusive"
              ]
            },
            "code_version": {
              "type": "string",
              "minLength": 4
            },
            "data_version": {
              "type": "string",
              "minLength": 4
            }
          }
        }
      }
    }
  }
}
