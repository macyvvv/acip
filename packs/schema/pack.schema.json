{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pack",
  "type": "object",
  "required": ["pack_id", "name", "objective", "scope", "ep_range", "dependencies", "done_conditions"],
  "properties": {
    "pack_id": {"type": "string"},
    "name": {"type": "string"},
    "objective": {"type": "string"},
    "scope": {"type": "string"},
    "ep_range": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 2,
      "maxItems": 2
    },
    "dependencies": {"type": "array", "items": {"type": "string"}},
    "done_conditions": {"type": "array", "items": {"type": "string"}}
  }
}
