.env
.env.*
!.env.example
__pycache__/
.DS_Store
*.pyc
node_modules/
dist/
build/
.runtime/
secrets/
.venv/
.venv.*/
.pytest_cache/

# somia generated render outputs — reproducible from specs, large binaries.
# Specs (script.md/prompt.md/metadata.json) are the source of truth, not the
# generated media. Keep these out of git; store finals in external storage.
somia/CONTENT/**/keyframe*.png
somia/CONTENT/**/video*.mp4
somia/CONTENT/**/*.dry_run.txt
somia/proto_images/

# system/core/file_lock.py's flock lock files -- empty, purely transient
# locking artifacts, never meaningful state. Scoped to system/runtime/ only,
# not a blanket *.lock, so this never shadows a real poetry.lock/Pipfile.lock.
system/runtime/**/*.lock

# Local-only Google Maps API key for the kabukicho_survival_map product,
# generated by build.py from .env -- never the committed/deployable
# bundle (web/public/kabukicho/ has no equivalent file and is tracked).
app/products/kabukicho_survival_map/local.config.js
