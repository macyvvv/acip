.env
.env.*
!.env.example
__pycache__/
.DS_Store
*.pyc
node_modules/
dist/
build/
.runtime/
secrets/
.venv/
.venv.*/
.pytest_cache/

# X OAuth 2.0 access/refresh token cache (platform/system/platform/scripts/publishing/providers_x.py)
# -- live, rotating secrets (X issues a new refresh_token on every refresh),
# not source; bootstrapped from .env's X_OAUTH2_ACCESS_TOKEN/X_OAUTH2_REFRESH_TOKEN
# on first use, then this file becomes authoritative.
platform/system/runtime/publishing/oauth2/
platform/system/runtime/publishing/oauth2/

# somia generated render outputs — reproducible from specs, large binaries.
# Specs (script.md/prompt.md/metadata.json) are the source of truth, not the
# generated media. Keep these out of git; store finals in external storage.
# (Path prefix corrected 2026-07-20: the actual content tree is
# businesses/somia/content/CONTENT/, not businesses/platform/somia/... --
# the old prefix never matched anything, so generated media was silently
# untracked-but-not-ignored. Patterns also widened to cover every filename
# shape the render scripts actually produce, not just keyframe/video.)
businesses/somia/content/CONTENT/**/keyframe*.png
businesses/somia/content/CONTENT/**/video*.mp4
businesses/somia/content/CONTENT/**/final_*.mp4
businesses/somia/content/CONTENT/**/final_*.png
businesses/somia/content/CONTENT/**/bridge_*.png
businesses/somia/content/CONTENT/**/a2start_*.png
businesses/somia/content/CONTENT/**/variant_*.mp4
businesses/somia/content/CONTENT/**/*_variant_*.mp4
businesses/somia/content/CONTENT/**/kling_reference_test.mp4
businesses/somia/content/CONTENT/**/*.wav
businesses/somia/content/CONTENT/**/final_concat_list.txt
businesses/somia/content/CONTENT/**/_check_*.png
businesses/somia/content/CONTENT/**/.final_act*_last_frame_candidates/
businesses/somia/content/CONTENT/**/sfx/
businesses/somia/content/CONTENT/**/*.dry_run.txt
businesses/somia/content/CONTENT/**/.fal_checkpoint_*.json
businesses/somia/content/proto_images/

# platform/system/core/file_lock.py's flock lock files -- empty, purely transient
# locking artifacts, never meaningful state. Scoped to platform/system/runtime/ only,
# not a blanket *.lock, so this never shadows a real poetry.lock/Pipfile.lock.
platform/system/runtime/**/*.lock
system/runtime/**/*.lock

# Local/generated Google Maps API key config for the kabukicho_survival_map
# product. Both files are browser-side artifacts emitted by build.py from
# .env / host env and can contain a live referrer-restricted key, so they
# must never be committed.
businesses/kabukicho_survival_map/app/local.config.js
platform/web/public/kabukicho_survival_map/local.config.js

# Kabukicho local maintenance reports generated by operator-side scripts.
# They contain ephemeral review output and machine-local paths; the DB/JSON
# data are the source of truth, not these reports.
businesses/kabukicho_survival_map/app/coordinate_fix_report.json
businesses/kabukicho_survival_map/app/nearby_coordinate_report.json

# Level 3b scheduler's local audit trail (ADR-0038,
# run_scheduled_execution.py) -- rewritten every wake, several times a day.
# Deliberately NOT the notification mechanism (that's the auto-opened PR
# when real work happens) -- git-tracking a file that changes on every
# no-op wake would dirty main's working tree between runs and could trip
# the scheduler's own "working tree must be clean before it touches
# anything" safety guard. The scheduler_paused.json kill-switch sentinel in
# the same directory IS tracked normally (a rare, deliberate human action,
# same as its three sibling switches).
platform/system/runtime/scheduler/audit/
system/runtime/scheduler/audit/

# ADR-0040's merge-circuit-breaker counter (scheduled_merge_circuit.py) --
# same reasoning as the audit trail above: it's mechanical, frequently-
# updated operational state (increments on every merge-gate failure, resets
# on success), not a rare deliberate human action like merge_paused.json
# (its sibling switch, which IS tracked normally).
platform/system/runtime/scheduler/merge_circuit.json
system/runtime/scheduler/merge_circuit.json
