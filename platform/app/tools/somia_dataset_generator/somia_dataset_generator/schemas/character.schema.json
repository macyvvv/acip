{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://somia.local/schemas/character.schema.json",
  "title": "Somia Character Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "character_id", "trigger_token", "adult",
    "identity_lock", "outfit_lock", "style_lock", "expression_register",
    "environment_register", "allowed_variation", "negative_lock",
    "cross_character_exclusions", "reference_interpretation",
    "identity_priority_note", "caption"
  ],
  "properties": {
    "schema_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+$"},
    "character_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
    "trigger_token": {"type": "string", "minLength": 3},
    "adult": {"const": true},
    "identity_lock": {"$ref": "#/$defs/nonEmptyStringArray"},
    "outfit_lock": {"$ref": "#/$defs/nonEmptyStringArray"},
    "style_lock": {"$ref": "#/$defs/nonEmptyStringArray"},
    "expression_register": {"$ref": "#/$defs/nonEmptyStringArray"},
    "environment_register": {"$ref": "#/$defs/nonEmptyStringArray"},
    "allowed_variation": {"$ref": "#/$defs/nonEmptyStringArray"},
    "negative_lock": {"$ref": "#/$defs/nonEmptyStringArray"},
    "cross_character_exclusions": {"$ref": "#/$defs/nonEmptyStringArray"},
    "reference_interpretation": {"type": "string", "minLength": 40},
    "identity_priority_note": {"type": "string", "minLength": 40},
    "caption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity_token", "fixed_tags"],
      "properties": {
        "identity_token": {"type": "string", "minLength": 3},
        "fixed_tags": {"$ref": "#/$defs/nonEmptyStringArray"}
      }
    }
  },
  "$defs": {
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 2}
    }
  }
}
