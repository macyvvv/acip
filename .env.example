OPENAI_API_KEY=
GITHUB_TOKEN=

# somia video rendering (see system/scripts/somia/providers.py)
# SOMIA_VIDEO_PROVIDER defaults to dry_run (no key needed, no network calls).
# Set to "pika" to render for real via fal.ai (Pika 2.2 is served through
# fal.ai's hosted queue API). SOMIA_VIDEO_API_KEY is then a fal.ai API key
# (https://fal.ai -> dashboard -> API keys), not a Pika-specific key.
SOMIA_VIDEO_PROVIDER=dry_run
SOMIA_VIDEO_API_KEY=
# Optional overrides for the pika provider (defaults shown):
# SOMIA_PIKA_KEYFRAME_MODEL=fal-ai/flux/schnell
# SOMIA_PIKA_DURATION=10   # Pika 2.2 only supports 5 or 10; somia specs are 12s
# SOMIA_PIKA_RESOLUTION=720p
