OPENAI_API_KEY=
GITHUB_TOKEN=

# kabukicho_survival_map's embedded Google Map (see
# businesses/kabukicho_survival_map/platform/app/architecture.md). Unlike the keys
# above, this is a browser-side Google Maps JavaScript API key -- it is
# NOT a server-side secret and will be visible to any visitor of the
# deployed site (view-source / network tab) once actually deployed. Its
# real protection is HTTP referrer restriction on the key itself in
# Google Cloud Console, not secrecy. Keeping it in .env only prevents it
# from landing in git history during local development; running
# businesses/kabukicho_survival_map/platform/app/build.py with this set writes a
# local gitignored local.config.js for dev use and also a deploy-artifact
# copy under platform/web/public/kabukicho/ so the public bundle can render
# the map when the key is present.
KABUKICHO_GMAPS_API_KEY=

# kabukicho_survival_map's deploy domain, e.g. https://kabukicho-survival.example.com
# (no trailing slash). Not a secret -- just unset until a host is chosen
# (deployment is explicitly gated on an SEO/AIO distribution strategy, see
# businesses/kabukicho_survival_map/platform/app/requirements.md). build.py uses it to
# generate sitemap.xml and the <link rel="canonical"> tag; both are skipped
# (not written with a placeholder) while this is empty, since a sitemap
# needs a real absolute URL to be valid.
KABUKICHO_SITE_URL=

# kabukicho_survival_map browser-side analytics / monetization identifiers.
# These are public IDs, not server-side secrets. build.py injects them into
# the deployable public bundle so GitHub Pages can load GA4 / AdSense
# without relying on a gitignored local.config.js file.
KABUKICHO_GA_ID=
KABUKICHO_ADSENSE_CLIENT=

# somia video rendering (see platform/system/platform/scripts/platform/somia/providers.py)
# SOMIA_VIDEO_PROVIDER defaults to dry_run (no key needed, no network calls).
# Both "kling" and "pika" render for real via fal.ai (both are hosted
# there, not through a vendor-specific API). SOMIA_VIDEO_API_KEY is a
# fal.ai API key (https://fal.ai -> dashboard -> API keys) either way.
# "kling" is the currently recommended provider — Pika 2.2 repeatedly
# drifted stylized/illustrated keyframes toward photorealism during
# testing and negative_prompt did not reliably prevent it.
SOMIA_VIDEO_PROVIDER=dry_run
SOMIA_VIDEO_API_KEY=
# Optional overrides for the kling provider (defaults shown):
# SOMIA_KLING_KEYFRAME_MODEL=fal-ai/flux/dev  # flux/schnell was observed dropping the character entirely
# SOMIA_KLING_DURATION=10   # Kling only supports 5 or 10; somia specs are 12s
# SOMIA_KLING_CFG_SCALE=0.5  # 0-1, how strictly it follows the motion prompt
# SOMIA_KLING_NEGATIVE_PROMPT=blur, distort, low quality, photorealistic, photo, realistic skin texture, 3D render, live action
# Optional overrides for the pika provider (kept for comparison, defaults shown):
# SOMIA_PIKA_KEYFRAME_MODEL=fal-ai/flux/dev
# SOMIA_PIKA_DURATION=10
# SOMIA_PIKA_RESOLUTION=720p
# SOMIA_PIKA_TIMEOUT_SECONDS=600
# SOMIA_PIKA_NEGATIVE_PROMPT=photorealistic, photo, realistic skin texture, 3D render, live action, camera flash
# Shared fal.ai queue poll timeout (used by both providers):
# SOMIA_FAL_TIMEOUT_SECONDS=600  # a real 10s/720p render observed ~316s
